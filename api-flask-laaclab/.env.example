# ==========================================================
# Ambiente: "development" usa SQLite | "production" usa MySQL
# ==========================================================
FLASK_ENV=development

# Chaves secretas (TROQUE em produção!)
SECRET_KEY=troque-esta-chave-secreta
JWT_SECRET_KEY=troque-esta-chave-jwt

# ----------------------------------------------------------
# SQLite (desenvolvimento) — caminho relativo à raiz do projeto
# ----------------------------------------------------------
SQLITE_PATH=laac_lab.db

# ----------------------------------------------------------
# MySQL (produção) — usado quando FLASK_ENV=production
# ----------------------------------------------------------
MYSQL_USER=root
MYSQL_PASSWORD=senha
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=LaaC_lab

# Tempo de expiração do access token (em horas)
JWT_ACCESS_TOKEN_HOURS=12
